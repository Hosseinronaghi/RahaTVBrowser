<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans-serif</item><item name="android:windowBackground">@color/app_background</item>
        <item name="android:colorAccent">@color/accent</item><item name="android:navigationBarColor">@color/app_background</item>
        <item name="android:statusBarColor">@color/app_background</item><item name="android:windowLightStatusBar">false</item>
        <item name="android:windowActionModeOverlay">true</item>
    </style>
    <style name="ToolbarButton">
        <item name="android:layout_width">43dp</item><item name="android:layout_height">42dp</item>
        <item name="android:layout_marginHorizontal">2dp</item><item name="android:background">@drawable/focusable_button</item>
        <item name="android:textColor">@color/text_primary</item><item name="android:textSize">17sp</item>
        <item name="android:gravity">center</item><item name="android:focusable">true</item><item name="android:clickable">true</item>
        <item name="android:stateListAnimator">@null</item><item name="android:minWidth">0dp</item><item name="android:minHeight">0dp</item>
        <item name="android:padding">0dp</item>
    </style>
</resources>
